# Custom Auth Settings
# IMPORTANT: JWT_SECRET_KEY must be at least 32 bytes (64 hex chars) for HS256 security.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_to_a_64_char_hex_string_generated_by_secrets_token_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Settings (Firebase)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=cahbot
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Vector Store Settings (Milvus)
MILVUS_HOST=vector-db
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=product_knowledge
EMBEDDING_DIMENSION=768

# WAHA Settings (WhatsApp HTTP API)
WAHA_BASE_URL=http://waha:3000
WAHA_SESSION=default
WAHA_API_KEY=your_waha_api_key_here
WHATSAPP_HOOK_HMAC_KEY=your_waha_hmac_secret_here

# WAHA Dashboard & Swagger Auth
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=your_password_here
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=your_password_here

# Gemini API Settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_ROUTER=gemini-2.0-flash-lite
GEMINI_MODEL_AGENT=gemini-2.0-flash-lite
GEMINI_MODEL_VISION=gemini-2.0-flash

# Chat Settings
CHAT_HISTORY_LIMIT=5
GEMINI_MODEL_EMBEDDING=gemini-embedding-001

# Owner/Seller Settings
OWNER_WHATSAPP_NUMBER=1234567890

# RAG Chunking Settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
